# ─── Server ───
PORT=3001

# ─── CORS ───
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://cashendar.yourdomain.com

# ─── MongoDB ───
# Include credentials when auth is enabled: mongodb://user:pass@DB_IP:27017/cashendar?authSource=cashendar
MONGODB_URI=mongodb://cashendar_app:STRONG_APP_PASSWORD@DB_PRIVATE_IP:27017/cashendar?authSource=cashendar

# Retry settings for DB connection
DB_MAX_RETRIES=5
DB_RETRY_DELAY_MS=5000

# ─── Authentication ───
# Set to 'true' to enforce JWT auth on protected routes
AUTH_ENABLED=true

# CHANGE THIS — use a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ─── OCR (bill scanning) ───
# Tesseract works out of the box (no config).
# EasyOCR (optional, better local accuracy): pip install easyocr
# Custom python binary for the EasyOCR sidecar (default: python3)
# EASYOCR_PYTHON=python3

# Mistral OCR (optional, best accuracy, cloud): create an API key at
# https://console.mistral.ai and set it here to enable the provider
# MISTRAL_API_KEY=
# MISTRAL_OCR_MODEL=mistral-ocr-latest
